{
  "expo": {
    "name": "My manager",
    "slug": "myManager",
    "scheme": "mymanager",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.personal.mymanager",
      "icon": "./assets/icon.png"
    },
    "android": {
      "package": "com.personal.mymanager",
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "monochromeImage": "./assets/android-icon-monochrome.png",
        "backgroundColor": "#0A0A0A"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "color": "#a2d2ff",
          "sounds": [
            "./assets/sounds/chime.wav",
            "./assets/sounds/bell.wav",
            "./assets/sounds/forest.wav",
            "./assets/sounds/soft.wav",
            "./assets/sounds/rest-end.wav",
            "./assets/sounds/hero.wav",
            "./assets/sounds/submarine.wav",
            "./assets/sounds/funk.wav"
          ]
        }
      ],
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
