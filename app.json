{
  "expo": {
    "name": "myManager",
    "slug": "myManager",
    "scheme": "mymanager",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.personal.mymanager"
    },
    "android": {
      "package": "com.personal.mymanager",
      "adaptiveIcon": {
        "backgroundColor": "#a2d2ff"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "color": "#a2d2ff",
          "sounds": ["./assets/sounds/chime.wav", "./assets/sounds/bell.wav", "./assets/sounds/forest.wav", "./assets/sounds/soft.wav", "./assets/sounds/rest-end.wav"]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
